---
import { getLangFromUrl } from "@lib/translate";

const lang = getLangFromUrl(Astro.url);

interface Props {
  alt: string;
  src: string;
  sizes?: string;
  breakpoints?: number[];
  ar?: number | string;
  className?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  attributes?: {
    picture?: Record<string, string>;
    img?: Record<string, string>;
  };
  focus?: string | null;
  layout?: "fill" | "fullWidth" | "fit" | undefined;
  crop?: boolean;
  artDirectives?: {
    media: string;
    breakpoints: number[];
    ar: number;
  }[];
}

let {
  src,
  sizes,
  breakpoints,
  alt,
  ar,
  className,
  loading,
  fetchpriority = "auto",
  attributes,
  layout,
  artDirectives,
  crop = true,
  focus: focusProp = undefined,
} = Astro.props;

const focus =
  typeof focusProp === "string" && focusProp.trim().length > 0
    ? focusProp.trim()
    : undefined;

const widths = breakpoints || [
  320, 375, 414, 512, 640, 682, 768, 840, 853, 950, 1024, 1056, 1067, 1280,
  1280, 1440, 1536, 1600, 1707, 1920, 2560,
];
const pictureAttributes = attributes?.picture || {};
const imgAttributes = attributes?.img || {};
const originalImageSize = src.split("/")[5].split("x");
const originalAspect: number =
  parseInt(originalImageSize[0], 10) / parseInt(originalImageSize[1], 10);

ar = parseFloat(ar + "") || originalAspect;

const getLayoutClass = () => {
  if (layout === "fill") return "w-full h-full object-cover";
  return "w-full h-auto object-fit";
};

const getHeight = (width: number, aspect: number) => {
  if (!!aspect) return Math.round(width / aspect);
  return Math.round(width / originalAspect);
};

const w = parseInt(originalImageSize[0], 10);
const h = getHeight(w, ar);

const createSourceAttributes = (
  format: string,
  breakpoints: number[],
  aspect: number,
) => {
  const filters = focus
    ? `filters:focal(${focus}):format(${format})${!crop ? ":fill(transparent)" : ""}`
    : `smart/filters:format(${format})${!crop ? ":fill(transparent)" : ""}`;
  let srscet = breakpoints
    .map(
      (width) =>
        `${src}/m/${!crop ? "fit-in/" : ""}${width}x${getHeight(
          width,
          aspect,
        )}/${filters} ${width}w`,
    )
    .join(", ");

  return {
    srcset: srscet,
    width: w,
    height: getHeight(w, aspect),
  };
};

const getBgImage = async () => {
  if (!src.includes(".jpg")) {
    return "";
  }

  const filters = focus
    ? `filters:focal(${focus}):format(jpg)${!crop ? ":fill(transparent)" : ""}`
    : `smart/filters:format(jpg)${!crop ? ":fill(transparent)" : ""}`;
  const url = `${src}/m/${!crop ? "fit-in/" : ""}${15}x${getHeight(15, ar)}/${filters}`;
  const response = await fetch(url);
  const bg = Buffer.from(await response.arrayBuffer()).toString("base64");
  return ` url(data:image/jpeg;base64,${bg})`;
};
let bgImage = await getBgImage();

const altParts = alt?.includes("|")
  ? alt.split("|").map((s) => s.trim())
  : null;
const langIndex: Record<string, number> = { en: 0, de: 2 };
const translatedAlt = altParts
  ? (altParts[langIndex[lang] ?? 0] ?? altParts[0]) || alt
  : alt;
---

<picture {...pictureAttributes} class={getLayoutClass()}>
  {
    artDirectives &&
      artDirectives.length > 0 &&
      artDirectives.map((breakpoint) => (
        <>
          <source
            media={breakpoint.media}
            {...createSourceAttributes(
              "avif",
              breakpoint.breakpoints,
              breakpoint.ar,
            )}
            sizes={sizes || "100vw"}
            type="image/avif"
          />
          <source
            media={breakpoint.media}
            {...createSourceAttributes(
              "webp",
              breakpoint.breakpoints,
              breakpoint.ar,
            )}
            sizes={sizes || "100vw"}
            type="image/webp"
          />
        </>
      ))
  }
  <source
    {...createSourceAttributes("avif", widths, ar)}
    type="image/avif"
    sizes={sizes || "100vw"}
  />
  <source
    {...createSourceAttributes("webp", widths, ar)}
    type="image/webp"
    sizes={sizes || "100vw"}
  />

  <img
    style={bgImage && `background-image:  ${bgImage}`}
    {...imgAttributes}
    src={`${src}/m/${!crop ? "fit-in/" : ""}100x${getHeight(100, ar)}/${focus ? `filters:focal(${focus})${!crop ? ":fill(transparent)" : ""}` : `smart${!crop ? "/filters:fill(transparent)" : ""}`}`}
    width={w}
    sizes={sizes || "100vw"}
    class={`${className || ""} ${getLayoutClass()}`}
    height={h !== 0 ? h : w}
    decoding="async"
    alt={translatedAlt || "image"}
    loading={loading || "lazy"}
    fetchpriority={fetchpriority}
  />
</picture>
<style>
  img {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
</style>
